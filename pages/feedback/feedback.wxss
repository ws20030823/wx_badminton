.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx 24rpx 140rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
}

.title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  border: 2rpx solid #ddd;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.input {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  border-radius: 12rpx;
  border: 2rpx solid #ddd;
  font-size: 28rpx;
  box-sizing: border-box;
}

.placeholder {
  color: #bbb;
}

.hint {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999;
}

.actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 40rpx 32rpx;
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  color: #fff;
  border: none;
  background: linear-gradient(135deg, #7c4dff 0%, #512da8 100%);
}

.btn-primary::after {
  border: none;
}

