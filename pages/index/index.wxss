/* pages/index/index.wxss - 首页样式 */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 顶部功能轮播：主卡片样式 */
.hero-swiper-wrap {
  padding: 32rpx 30rpx 28rpx;
}

.hero-swiper {
  height: 210rpx;
}

.hero-card {
  height: 100%;
  border-radius: 24rpx;
  padding: 30rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.45);
}

.hero-card-create {
  background: linear-gradient(135deg, #0b1f3a 0%, #0f447a 45%, #14b66a 100%);
}

.hero-card-matches {
  background: linear-gradient(135deg, #102a6b 0%, #2563eb 45%, #7e57ff 100%);
}

.hero-card-profile {
  background: linear-gradient(135deg, #0f2f47 0%, #059669 45%, #7c3aed 100%);
}

.hero-text {
  flex: 1;
  min-width: 0;
}

.hero-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.hero-sub {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 6rpx;
}

.hero-sub:last-of-type {
  margin-bottom: 0;
}

.hero-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  color: #ffffff;
  margin-left: 24rpx;
}

/* 区块标题 */
.section {
  padding: 0 30rpx 30rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-header-row {
  justify-content: space-between;
  align-items: center;
}

.section-left {
  display: flex;
  align-items: center;
}

.section-bar {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #14b66a;
  margin-right: 14rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-link {
  font-size: 26rpx;
  color: #999;
}

/* 模式卡片行 - 3D 风格 */
.mode-row {
  display: flex;
  gap: 24rpx;
}

.mode-card-3d {
  flex: 1;
  background: #f5f5f5;
  border-radius: 20rpx;
  padding: 26rpx 24rpx 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  position: relative;
  opacity: 0;
  transform: translateY(16rpx);
  transition: opacity 450ms ease-out, transform 450ms ease-out;
}

.mode-card-3d:active {
  transform: translateY(20rpx) scale(0.98);
}

.card-loaded {
  opacity: 1;
  transform: translateY(0);
}

.mode-tag {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #7c3aed;
  background: rgba(124, 58, 237, 0.08);
  border: 1rpx solid rgba(124, 58, 237, 0.5);
  margin-bottom: 16rpx;
}

.mode-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.mode-text {
  flex: 1;
  min-width: 0;
}

.mode-title-large {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #111827;
  margin-bottom: 6rpx;
}

.mode-subtitle {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
}

.mode-illustration {
  width: 96rpx;
  height: 96rpx;
  border-radius: 999rpx;
  background: radial-gradient(circle at 30% 30%, #ffffff, #dbeafe);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
}

.mode-card-doubles .mode-illustration {
  background: radial-gradient(circle at 30% 30%, #ffffff, #ede9fe);
}

.mode-emoji {
  font-size: 48rpx;
}

/* 战绩卡片 */
.record-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #fafafa;
  border-radius: 16rpx;
}

.record-item:active {
  opacity: 0.9;
}

.record-main {
  flex: 1;
  min-width: 0;
}

.record-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-meta {
  font-size: 24rpx;
  color: #999;
}

.record-stats {
  flex-shrink: 0;
  margin-left: 24rpx;
}

.stat-wins {
  font-size: 26rpx;
  color: #2e7d32;
  font-weight: 500;
  margin-right: 16rpx;
}

.stat-losses {
  font-size: 26rpx;
  color: #999;
}

.record-empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 24rpx 32rpx;
}

.record-empty-icon-wrap {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.record-empty-calendar {
  font-size: 80rpx;
  color: #d1d5db;
}

.record-empty-x {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 44rpx;
  font-weight: bold;
  color: #ef4444;
}

.record-empty-text {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  margin-bottom: 28rpx;
}

.record-empty-btn {
  background: #1565c0;
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 12rpx;
  padding: 20rpx 48rpx;
  border: none;
}

.record-empty-btn::after {
  border: none;
}

.page-bottom {
  height: 40rpx;
}
