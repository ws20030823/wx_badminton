<view class="page">
  <view class="hero-swiper-wrap">
    <swiper class="hero-swiper" indicator-dots="{{true}}" autoplay="{{true}}" interval="5000" circular="{{true}}">
      <swiper-item>
        <view class="hero-card hero-card-create" bindtap="onHeroTap" data-type="create">
          <view class="hero-text">
            <text class="hero-title">快速创建比赛</text>
            <text class="hero-sub">智能匹配水平相近的球友</text>
            <text class="hero-sub">自动生成公平对局</text>
          </view>
          <view class="hero-icon">🏸</view>
        </view>
      </swiper-item>
      <swiper-item>
        <view class="hero-card hero-card-matches" bindtap="onHeroTap" data-type="matches">
          <view class="hero-text">
            <text class="hero-title">查看我的比赛</text>
            <text class="hero-sub">报名状态与历史战绩一目了然</text>
          </view>
          <view class="hero-icon">📋</view>
        </view>
      </swiper-item>
      <swiper-item>
        <view class="hero-card hero-card-profile" bindtap="onHeroTap" data-type="profile">
          <view class="hero-text">
            <text class="hero-title">完善个人资料</text>
            <text class="hero-sub">设置头像与等级,让队友更了解你</text>
          </view>
          <view class="hero-icon">😊</view>
        </view>
      </swiper-item>
    </swiper>
  </view>
  <view class="section">
    <view class="section-header">
      <view class="section-bar"></view>
      <text class="section-title">选择模式</text>
    </view>
    <view class="mode-row">
      <view class="mode-card-3d mode-card-singles {{loaded ? 'card-loaded' : ''}}" bindtap="onSinglesTap">
        <view class="mode-tag">1v1 竞技</view>
        <view class="mode-main">
            <text class="mode-title-large">单打对战</text>
            <text class="mode-subtitle">SOLO 荣耀 挑战自我极限</text>
          </view>
          <view class="mode-illustration">
            <text class="mode-emoji">🏸</text>
          </view>
      </view>
      <view class="mode-card-3d mode-card-doubles {{loaded ? 'card-loaded' : ''}}" bindtap="onDoublesTap">
        <view class="mode-tag">2v2 配合</view>
        <view class="mode-main">
            <text class="mode-title-large">双打组队</text>
            <text class="mode-subtitle">默契配合 乐趣加倍</text>
          </view>
          <view class="mode-illustration">
            <text class="mode-emoji">👥</text>
          </view>
      </view>
    </view>
  </view>
  <view class="section">
    <view class="section-header section-header-row">
      <view class="section-left">
        <view class="section-bar"></view>
        <text class="section-title">最近战绩</text>
      </view>
      <text class="section-link" bindtap="onViewAllRecords">查看全部 ></text>
    </view>
    <view class="record-card">
      <view wx:if="{{recentRecords.length > 0}}" class="record-list">
        <view class="record-item" wx:for="{{recentRecords}}" wx:key="_id" data-id="{{item._id}}" bindtap="onRecordTap">
          <view class="record-main">
            <text class="record-name">{{item.name}}</text>
            <text class="record-meta">{{item.dateStr}} &#183; {{item.typeText}} - {{item.subModeText}}</text>
          </view>
          <view class="record-stats">
            <text class="stat-wins">胜 {{item.myWins}}</text>
            <text class="stat-losses">负 {{item.myLosses}}</text>
          </view>
        </view>
      </view>
      <view wx:else class="record-empty-wrap">
        <view class="record-empty-icon-wrap">
          <text class="record-empty-calendar">📅</text>
          <text class="record-empty-x">✕</text>
        </view>
        <text class="record-empty-text">本周暂无比赛记录,手痒了吗?</text>
        <button class="record-empty-btn" bindtap="onStartChallenge">发起挑战</button>
      </view>
    </view>
  </view>
  <view class="page-bottom"></view>
</view>
