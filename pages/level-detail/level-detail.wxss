.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx 24rpx 40rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
}

.title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.level-card .level-header {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
  gap: 12rpx;
}

.level-badge {
  font-size: 26rpx;
  font-weight: bold;
  padding: 4rpx 20rpx;
  border-radius: 999rpx;
  color: #fff;
}

.level-badge.beginner {
  background: #42a5f5;
}

.level-badge.intermediate {
  background: #66bb6a;
}

.level-badge.advanced {
  background: #ab47bc;
}

.level-sub {
  font-size: 24rpx;
  color: #888;
}

.level-desc {
  display: block;
  font-size: 26rpx;
  color: #555;
  line-height: 1.7;
}

.tip-card .title {
  margin-bottom: 8rpx;
}

