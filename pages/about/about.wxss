.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx 24rpx 40rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
}

.title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.bullet {
  display: flex;
  align-items: flex-start;
  margin-top: 8rpx;
}

.bullet .dot {
  width: 24rpx;
  font-size: 28rpx;
  line-height: 1.4;
  color: #666;
}

.bullet .text {
  flex: 1;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.email {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #1565c0;
}

